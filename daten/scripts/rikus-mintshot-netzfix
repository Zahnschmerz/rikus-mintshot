#!/usr/bin/env python3
# Rikus Mintshot — Netzwerk-Portabilitaet fuer den Klon.
# Ubuntu/Mint bindet WLAN-/LAN-Verbindungen in /etc/netplan/*.yaml fest an den
# Interface-NAMEN der Klon-Quelle: »match: name: "<karte>"« (z.B. "wlp0s20f3").
# Auf FREMDER Hardware heisst die Karte anders -> die Verbindung (mitsamt
# gespeichertem WLAN-Passwort) wird ignoriert, das WLAN bleibt unverbunden.
#
# FIX: den festen Interface-Namen im match-Block durch einen PLATZHALTER ersetzen,
# der auf jede Karte desselben Typs passt -- WLAN -> "wl*", Ethernet -> "e*".
# NetworkManager (nutzt netplan als Backend) erzeugt daraus »interface-name=wl*«
# und bindet die Verbindung an die vorhandene Karte. Passwort/SSID/Rest bleiben.
#
# WICHTIG: den match-Block NICHT komplett loeschen! Dann macht netplan den
# Verbindungs-NAMEN (z.B. "NM-8fb7...") zum Interface-Namen -> existiert nicht ->
# Verbindung tot. (Genau dieser Fehler trat in der ersten Fassung auf.)
# Ebenso wird eine »macaddress:«-Bindung entfernt (haengt an der konkreten Karte).
import glob, re, sys, os, shutil, subprocess

# ---------------------------------------------------------------------------
# SICHERHEITSNETZ (20.07.2026) — zweiter Weg fuer die WLAN-Zugangsdaten.
#
# Das Problem: Die gespeicherten Verbindungen liegen im Klon NUR in
# /etc/netplan/*.yaml. Daraus baut ein Hilfsprogramm beim Start die Dateien in
# /run/NetworkManager/system-connections/. Geht dabei irgendetwas schief, kennt
# NetworkManager die Verbindung nicht — die Karte laeuft, findet alle Netze,
# aber das eigene WLAN ist "vergessen". Genau dieses Bild trat am 20.07. auf
# einem Klon auf, obwohl die netplan-Datei nachweislich fehlerfrei im Abbild lag.
#
# Die Loesung: beim BAU eine Kopie der Verbindungen ins Abbild legen (--sichern),
# beim START pruefen, ob NetworkManager sie kennt — und nur die FEHLENDEN direkt
# als NetworkManager-Datei zurueckschreiben. Im Normalfall passiert nichts.
SICHERUNG = '/usr/local/share/rikus-mintshot/netz-sicherung'


def _portabel(text):
    """Bindung an die konkrete Karte der Quelle loesen (wie beim netplan-Fix)."""
    typ = re.search(r'^type=(\S+)', text, re.M)
    platzhalter = 'wl*' if (typ and typ.group(1) == 'wifi') else 'e*'
    text = re.sub(r'^interface-name=.*$', 'interface-name=' + platzhalter + ';',
                  text, flags=re.M)
    return re.sub(r'^mac-address=.*\n?', '', text, flags=re.M)


if '--sichern' in sys.argv:
    # Laeuft als root beim Bau, BEVOR der Klon gezogen wird. Nur Kopieren, sonst nichts.
    os.makedirs(SICHERUNG, exist_ok=True)
    for alt in glob.glob(os.path.join(SICHERUNG, '*.nmconnection')):
        os.remove(alt)                       # alte Sicherung nie mitschleppen
    anzahl = 0
    for quelle in ('/run/NetworkManager/system-connections',
                   '/etc/NetworkManager/system-connections'):
        for f in glob.glob(os.path.join(quelle, '*.nmconnection')):
            try:
                inhalt = open(f).read()
            except OSError:
                continue
            # nur echte WLAN-/Kabel-Verbindungen; lo, Bruecken und VM-Adapter (vnet*)
            # erzeugt NetworkManager selbst neu — die gehoeren nicht ins Abbild.
            if not re.search(r'^type=(wifi|802-11-wireless|ethernet|802-3-ethernet)$',
                             inhalt, re.M):
                continue
            ziel = os.path.join(SICHERUNG, os.path.basename(f))
            shutil.copyfile(f, ziel)
            os.chmod(ziel, 0o600)
            anzahl += 1
    print(f"netzfix: {anzahl} Netz-Verbindung(en) fuer den Klon gesichert -> {SICHERUNG}")
    sys.exit(0)

geaendert = 0
for f in glob.glob('/etc/netplan/*.yaml'):
    try:
        lines = open(f).read().split('\n')
    except OSError:
        continue
    out, in_match, mind, hit = [], False, None, False
    for line in lines:
        ind = len(line) - len(line.lstrip())
        s = line.strip()
        if s == 'match:':
            in_match = True; mind = ind; out.append(line); continue
        if in_match and (s == '' or ind > mind):
            m = re.match(r'^(\s*name:\s*")([^"]*)(".*)$', line)
            if m:
                name = m.group(2)
                if name.startswith('wl'):
                    g = 'wl*'          # jedes WLAN-Interface (wlp*/wlan*/wlo*/wlx*)
                elif name.startswith('e'):
                    g = 'e*'           # jedes Ethernet-Interface (enp*/eth*/eno*/ens*)
                else:
                    g = name           # unbekannter Typ: unveraendert lassen
                if g != name:
                    out.append(m.group(1) + g + m.group(3)); hit = True; continue
                out.append(line); continue
            if re.match(r'^\s*macaddress:', line):   # MAC bindet an DIE Karte -> weg
                hit = True; continue
            out.append(line); continue
        in_match = False
        out.append(line)
    if hit:
        try:
            open(f, 'w').write('\n'.join(out)); geaendert += 1
        except OSError:
            pass
print(f"netzfix: {geaendert} netplan-Datei(en) auf Interface-Platzhalter (wl*/e*) umgestellt")

# Mit "--apply" (so ruft der Boot-Dienst rikus-mintshot-netzfix.service auf): nur wenn
# wirklich etwas umgestellt wurde, netplan sofort neu anwenden -> NetworkManager uebernimmt
# die portable Bindung, das gespeicherte WLAN verbindet auf der fremden Karte. Beim LIVE-Boot
# passiert das automatisch, nicht erst nach einer Installation. Steht schon "wl*" drin (jeder
# weitere Boot), wird nichts angewendet -> kein unnoetiger Netz-Neustart.
if geaendert and '--apply' in sys.argv:
    print("netzfix: wende die Umstellung an (netplan apply) ...")
    subprocess.run(['netplan', 'apply'], check=False)

# ---------------------------------------------------------------------------
# SICHERHEITSNETZ, zweiter Teil: fehlende Verbindungen zurueckholen.
# Laeuft beim Start (Dienst ruft mit --apply auf), NACH NetworkManager. Es wird nur
# eingegriffen, wenn eine gesicherte Verbindung NICHT bekannt ist — sonst passiert
# nichts (keine doppelten Eintraege, kein Netz-Neustart).
if '--apply' in sys.argv and os.path.isdir(SICHERUNG):
    try:
        r = subprocess.run(['nmcli', '-t', '-f', 'UUID', 'connection', 'show'],
                           capture_output=True, text=True, timeout=30)
        bekannt = {z.strip() for z in r.stdout.split('\n') if z.strip()}
    except Exception:
        bekannt = None          # nmcli nicht ansprechbar -> lieber nichts anfassen

    zurueck = 0
    if bekannt is not None:
        ZIEL = '/etc/NetworkManager/system-connections'
        for f in sorted(glob.glob(os.path.join(SICHERUNG, '*.nmconnection'))):
            try:
                inhalt = open(f).read()
            except OSError:
                continue
            m = re.search(r'^uuid=(\S+)', inhalt, re.M)
            if not m or m.group(1) in bekannt:
                continue                     # NetworkManager kennt sie -> nichts zu tun
            try:
                os.makedirs(ZIEL, exist_ok=True)
                # Name ohne den "netplan-"-Vorsatz, sonst haelt netplan sie faelschlich
                # fuer eine von ihm erzeugte Datei und raeumt sie beim naechsten Lauf weg.
                name = re.sub(r'^netplan-', '', os.path.basename(f))
                ziel = os.path.join(ZIEL, name)
                with open(ziel, 'w') as z:
                    z.write(_portabel(inhalt))
                os.chmod(ziel, 0o600)        # NetworkManager lehnt offenere Rechte ab
                zurueck += 1
                print(f"netzfix: Verbindung fehlte in NetworkManager -> wiederhergestellt: {name}")
            except OSError as fehler:
                print(f"netzfix: konnte {os.path.basename(f)} nicht zurueckschreiben: {fehler}")

    if zurueck:
        subprocess.run(['nmcli', 'connection', 'reload'], check=False)
        print(f"netzfix: {zurueck} Verbindung(en) aus der Sicherung zurueckgeholt")
